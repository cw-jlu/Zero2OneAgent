# 使用 OpenAI 兼容接口，填你自己的 key
# 支持 deepseek / openai / 阿里云 Maas 等兼容 openai 格式的服务
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# agent loop 参数
MAX_LOOP_STEPS=10
MAX_TURNS=20
COMPRESS_THRESHOLD=16

# 代理配置（可选：用于联网搜索工具访问境外网站）
# HTTP_PROXY=http://127.0.0.1:7892
# HTTPS_PROXY=http://127.0.0.1:7892
# 本地与国内大模型服务（如阿里云）不走代理，保障速度
# NO_PROXY=127.0.0.1,localhost,maas.aliyuncs.com
