# 支持任何 OpenAI 兼容接口（DS/OpenAI/qwen/阿里云Maas等），只要改参数值就行。
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 最大对话轮次（超过后触发压缩）
MAX_TURNS=20
# 单次 agent loop 最大迭代次数
MAX_LOOP_STEPS=10
# 触发历史压缩的阈值（消息数）
COMPRESS_THRESHOLD=16

# 代理配置（可选：用于联网搜索工具访问境外网站）
# HTTP_PROXY=http://127.0.0.1:7892
# HTTPS_PROXY=http://127.0.0.1:7892
# 本地与国内大模型服务不走代理，保障速度
# NO_PROXY=127.0.0.1,localhost,maas.aliyuncs.com
